APP_NAME=Forms

SESSION_NAME=forms_session
SESSION_COOKIE_SECURE=0
SESSION_COOKIE_SAMESITE=Lax

DB_DRIVER=sqlite
DB_SQLITE_PATH=./data/app.sqlite

# Пример MySQL-настроек (раскомментируйте и измените при необходимости):
# DB_DRIVER=mysql
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=forms
# DB_USERNAME=root
# DB_PASSWORD=
# DB_CHARSET=utf8mb4

CAPTCHA_PROVIDER=yandex

# Yandex SmartCaptcha (здесь ДОЛЖНЫ быть фейковые/пустые значения)
YANDEX_CLIENT_KEY=dummy_yandex_client_key
YANDEX_SERVER_KEY=dummy_yandex_server_key

# Google reCAPTCHA v2 (также только примеры)
RECAPTCHA_SITE_KEY=dummy_recaptcha_site_key
RECAPTCHA_SECRET_KEY=dummy_recaptcha_secret_key

